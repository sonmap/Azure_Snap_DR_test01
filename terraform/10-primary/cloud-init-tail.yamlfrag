        if mysqladmin --protocol=socket -uroot ping --silent; then
          break
        fi
        sleep 2
      done

      if ! mysqladmin --protocol=socket -uroot ping --silent; then
        echo "MySQL did not become ready." >&2
        journalctl -u mysql --no-pager -n 100 || true
        exit 1
      fi

      systemctl restart dr-metadata.service
      systemctl start tomcat9
      systemctl restart dr-health.service
      systemctl start dr-metadata.timer dr-health.timer
